# ╔══════════════════════════════════════════════════════════════╗
# ║  Crispy Kitsune — .env.example                              ║
# ║  Location: ~/.openclaw/.env                                 ║
# ║  Permissions: chmod 600 ~/.openclaw/.env                    ║
# ║  Referenced in openclaw.json via ${VARIABLE_NAME}           ║
# ╚══════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────
# REQUIRED — Gateway will not start without these
# ─────────────────────────────────────────────────────────────

# OpenClaw gateway authentication token
# Generate: openclaw doctor --generate-gateway-token
OPENCLAW_GATEWAY_TOKEN=

# OpenRouter — hub for multi-model access (Opus, DeepSeek, Gemini, etc.)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-

# Telegram Bot — Crispy's primary channel
# Get token: Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Google Gemini — embeddings for memory search + heartbeat tasks
# Get key: https://aistudio.google.dev/apikey
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# RECOMMENDED — Essential for full features
# ─────────────────────────────────────────────────────────────

# Admin Telegram User IDs (for elevated access)
# Get yours: Telegram → @userinfobot → /start
TELEGRAM_MARTY_ID=
TELEGRAM_WENTING_ID=

# GitHub — pushing workspace changes to FancyKat/crispy-kitsune
# Get token: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=github_pat_

# Brave Search — web search tool for research
# Get key: https://api-dashboard.search.brave.com
BRAVE_API_KEY=BSA

# ElevenLabs — text-to-speech for voice messages
# Get key: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Add when needed
# ─────────────────────────────────────────────────────────────

# Mem0 — automatic memory capture plugin
# Get key: https://app.mem0.ai (or self-host)
# MEM0_API_KEY=m0-

# Discord Bot — multi-channel support
# Get token: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=

# Webhook hooks token — for Gmail/email ingestion
# Generate: openssl rand -hex 32
# OPENCLAW_HOOKS_TOKEN=

# GOG Galaxy keyring — for gaming skill
# GOG_KEYRING_PASSWORD=

# ─────────────────────────────────────────────────────────────
# SPECIAL AUTH (not in .env — handled separately)
# ─────────────────────────────────────────────────────────────
# OpenAI Codex: OAuth auto-refresh
#   Run: openclaw models auth paste-token --provider openai-codex
#   Stored in: ~/.openclaw/agents/<agentId>/agent/auth-profiles.json
#
# Anthropic Claude: Routes through OpenRouter (no separate key)
